# TradingBot env template — copy to .env and fill locally
# Never commit real keys. Keep live trading blocked.

# --- xAI / Grok ---
XAI_API_KEY=

# --- Toss Securities Open API (canonical) ---
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCESS_TOKEN=
TOSS_REFRESH_TOKEN=
TOSS_ACCOUNT_ID=
TOSS_ACCOUNT_NUMBER=
TOSS_ACCOUNT_SEQ=
TOSS_API_BASE_URL=https://openapi.tossinvest.com
TOSS_API_ENV=sandbox

# --- Toss legacy aliases (optional) ---
TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=

# --- Trading safety defaults (fail-closed) ---
ALLOW_LIVE_ORDERS=false
KILL_SWITCH=true
ORDER_MODE=dry_run
MAX_ORDER_NOTIONAL=
MAX_DAILY_LOSS=
MAX_POSITION_SIZE=
MAX_SYMBOL_POSITION_RATIO=
MAX_OPEN_ORDERS=
MARKET_DATA_MAX_STALENESS_SECONDS=5

# --- Context7 free keys (rotation 1→6) ---
CONTEXT7_API_KEY_1=
CONTEXT7_API_KEY_2=
CONTEXT7_API_KEY_3=
CONTEXT7_API_KEY_4=
CONTEXT7_API_KEY_5=
CONTEXT7_API_KEY_6=
