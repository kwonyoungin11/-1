<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TradingBot.App.App"
             xmlns:local="using:TradingBot.App"
             RequestedThemeVariant="Light">
  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>
  <Application.Resources>
    <Color x:Key="BgApp">#F4F7FB</Color>
    <Color x:Key="BgCard">#FFFFFF</Color>
    <Color x:Key="BgMuted">#F1F5F9</Color>
    <Color x:Key="BorderSoft">#E2E8F0</Color>
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="Accent">#2563EB</Color>
    <Color x:Key="Up">#089981</Color>
    <Color x:Key="Down">#F23645</Color>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window.glass-root">
      <Setter Property="Background" Value="#F4F7FB"/>
      <Setter Property="Foreground" Value="#0F172A"/>
    </Style>

    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#0F172A"/>
    </Style>
    <Style Selector="TextBlock.headline">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#B91C1C"/>
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#334155"/>
      <Setter Property="LetterSpacing" Value="0.3"/>
    </Style>
    <Style Selector="TextBlock.section-blue">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#1D4ED8"/>
    </Style>
    <Style Selector="TextBlock.sub">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#64748B"/>
    </Style>
    <Style Selector="TextBlock.metric">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#0F172A"/>
    </Style>
    <Style Selector="TextBlock.big-warn">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#DC2626"/>
    </Style>

    <Style Selector="Border.glass-bar">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#E2E8F0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BoxShadow" Value="0 4 16 0 #14000000"/>
    </Style>
    <Style Selector="Border.glass-card">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#E2E8F0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BoxShadow" Value="0 2 12 0 #0F000000"/>
    </Style>
    <Style Selector="Border.glass-danger">
      <Setter Property="Background" Value="#FEF2F2"/>
      <Setter Property="BorderBrush" Value="#FECACA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="Border.glass-action">
      <Setter Property="Background" Value="#EFF6FF"/>
      <Setter Property="BorderBrush" Value="#BFDBFE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="Border.glass-row">
      <Setter Property="Background" Value="#F8FAFC"/>
      <Setter Property="BorderBrush" Value="#E2E8F0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="Border.pill-kill">
      <Setter Property="Background" Value="#FEE2E2"/>
      <Setter Property="BorderBrush" Value="#FECACA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>
    <Style Selector="Border.pill-lock">
      <Setter Property="Background" Value="#FEF2F2"/>
      <Setter Property="BorderBrush" Value="#FECACA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>
    <Style Selector="Border.pill-mode">
      <Setter Property="Background" Value="#EFF6FF"/>
      <Setter Property="BorderBrush" Value="#BFDBFE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>
    <Style Selector="Border.pill-ok">
      <Setter Property="Background" Value="#ECFDF5"/>
      <Setter Property="BorderBrush" Value="#A7F3D0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>
    <Style Selector="Border.pill-kill TextBlock, Border.pill-lock TextBlock">
      <Setter Property="Foreground" Value="#B91C1C"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Border.pill-mode TextBlock">
      <Setter Property="Foreground" Value="#1D4ED8"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Border.pill-ok TextBlock">
      <Setter Property="Foreground" Value="#047857"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.glass-btn">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.glass-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1D4ED8"/>
    </Style>
    <Style Selector="Button.glass-btn-stop">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="Foreground" Value="#B45309"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderBrush" Value="#FDBA74"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#CBD5E1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Foreground" Value="#0F172A"/>
    </Style>
  </Application.Styles>
</Application>
