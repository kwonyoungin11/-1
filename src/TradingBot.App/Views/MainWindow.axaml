<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TradingBot.App.ViewModels"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="TradingBot.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Classes="glass-root"
        Width="1200" Height="820"
        MinWidth="960" MinHeight="680"
        TransparencyLevelHint="AcrylicBlur,Blur,Transparent"
        Background="#E00B1220"
        ExtendClientAreaToDecorationsHint="True"
        Title="{Binding Title}">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <!-- 위 2/3 차트 · 아래 1/3 조작 -->
  <Grid RowDefinitions="2*,*" Margin="12,32,12,12">

    <!-- ===== 차트 영역 (상단 2/3) ===== -->
    <Border Grid.Row="0" Classes="glass-card" Margin="0,0,0,10" Padding="10">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="4,0,4,8">
          <StackPanel Spacing="2">
            <TextBlock Classes="section" Text="{Binding ChartTitle}"/>
            <TextBlock Classes="sub" Text="연습 차트 · 초록=매수 표시 · 빨강=매도 표시 · 실주문 없음"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
            <Border Classes="pill-lock"><TextBlock Text="실거래 잠김"/></Border>
            <Border Classes="pill-ok"><TextBlock Text="연습"/></Border>
          </StackPanel>
        </Grid>
        <lvc:CartesianChart Grid.Row="1"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            TooltipPosition="Top"
                            ZoomMode="X"
                            Background="#00000000"/>
      </Grid>
    </Border>

    <!-- ===== 조작 영역 (하단 1/3) ===== -->
    <Border Grid.Row="1" Classes="glass-bar" Padding="14">
      <Grid ColumnDefinitions="2*,*,*,Auto" ColumnSpacing="14">

        <!-- 대상 주식 · 전략 · 시작/종료 -->
        <StackPanel Spacing="8">
          <TextBlock Classes="section" Text="자동매매 조작"/>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="10">
            <TextBlock Classes="sub" Text="대상 주식" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding StockKindOptions}"
                      SelectedItem="{Binding SelectedStockKind}" MinWidth="160"/>
            <TextBlock Grid.Row="1" Classes="sub" Text="매매 전략" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding StrategyOptions}"
                      SelectedItem="{Binding SelectedStrategy}" MinWidth="160"/>
            <TextBlock Grid.Row="2" Classes="sub" Text="관심 종목" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WatchSymbolsText}"
                       TextWrapping="Wrap" VerticalAlignment="Center"/>
          </Grid>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button Classes="glass-btn" Content="자동매매 시작"
                    Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
            <Button Classes="glass-btn-stop" Content="자동매매 종료"
                    Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"/>
            <Button Classes="glass-btn" Content="새로고침"
                    Command="{Binding RefreshCommand}" IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>
          <TextBlock Classes="sub" Text="{Binding SafetyNote}" TextWrapping="Wrap"/>
          <TextBlock Classes="sub" Text="{Binding StatusLine}"/>
        </StackPanel>

        <!-- 잔액 -->
        <Border Classes="glass-card" Grid.Column="1" Padding="12">
          <StackPanel Spacing="6" VerticalAlignment="Center">
            <TextBlock Classes="section" Text="잔액"/>
            <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding BalanceLabel}" TextWrapping="Wrap"/>
            <TextBlock Classes="sub" Text="{Binding SessionStatusLabel, StringFormat=상태 · {0}}"/>
          </StackPanel>
        </Border>

        <!-- 수익률 -->
        <Border Classes="glass-card" Grid.Column="2" Padding="12">
          <StackPanel Spacing="6" VerticalAlignment="Center">
            <TextBlock Classes="section" Text="수익률"/>
            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#4ADE80"
                       Text="{Binding ReturnRateLabel}"/>
            <TextBlock Classes="sub" Text="연습 기준 · 실계좌 아님"/>
          </StackPanel>
        </Border>

        <!-- 범례 -->
        <StackPanel Grid.Column="3" Spacing="8" VerticalAlignment="Center" MinWidth="120">
          <TextBlock Classes="section" Text="차트 표시"/>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Ellipse Width="10" Height="10" Fill="#00E676"/>
            <TextBlock Text="매수" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Ellipse Width="10" Height="10" Fill="#FF5252"/>
            <TextBlock Text="매도" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Classes="sub" TextWrapping="Wrap" Text="실행 주문 버튼 없음"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
