<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TradingBot.App.ViewModels"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1320" d:DesignHeight="880"
        x:Class="TradingBot.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Classes="glass-root"
        Width="1320" Height="880"
        MinWidth="1040" MinHeight="720"
        Background="#F4F7FB"
        ExtendClientAreaToDecorationsHint="True"
        Title="{Binding Title}">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <!-- Chart row must stay dominant; bottom panel capped so chart never collapses -->
  <Grid RowDefinitions="Auto,3*,Auto" Margin="16,36,16,14">

    <!-- Top bar -->
    <Border Classes="glass-card" Padding="14,10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock Classes="title" Text="{Binding Title}"/>
          <TextBlock Classes="sub" Text="{Binding SafetyHeadline}" TextWrapping="Wrap"/>
          <TextBlock Classes="sub" Text="{Binding OfficialStrategyLabel}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Classes="pill-lock"><TextBlock Text="실주문 잠금"/></Border>
          <Border Classes="pill-ok"><TextBlock Text="{Binding ConnectionPill}"/></Border>
          <Border Classes="pill-mode"><TextBlock Text="SPCX"/></Border>
          <Border Classes="pill-mode"><TextBlock Text="Light UI"/></Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Chart: price + volume panes (always min height) -->
    <Border Grid.Row="1" Classes="glass-card" Padding="8" Margin="0,0,0,10" Background="#FFFFFF"
            MinHeight="420" VerticalAlignment="Stretch">
      <Grid RowDefinitions="Auto,2.4*,0.9*" MinHeight="400">
        <Grid ColumnDefinitions="*,Auto" Margin="6,2,6,6">
          <StackPanel Spacing="2">
            <TextBlock Classes="section" Text="{Binding ChartTitle}" FontSize="14"/>
            <TextBlock Classes="sub" Text="{Binding ChartSubtitle}"/>
            <TextBlock Classes="sub" Text="{Binding IndicatorLegend}" Foreground="#475569"/>
            <TextBlock Classes="metric" Text="{Binding LastPriceLabel}" FontSize="12"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
            <Border Classes="pill-mode" Padding="8,4"><TextBlock Text="KST"/></Border>
            <Border Classes="pill-mode" Padding="8,4"><TextBlock Text="Crosshair"/></Border>
            <Border Classes="pill-mode" Padding="8,4"><TextBlock Text="Sections"/></Border>
          </StackPanel>
        </Grid>
        <!-- Price pane -->
        <lvc:CartesianChart Grid.Row="1"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            Sections="{Binding Sections}"
                            DrawMarginFrame="{Binding DrawMarginFrame}"
                            DrawMargin="{Binding DrawMargin}"
                            TooltipPosition="Top"
                            FindingStrategy="CompareOnlyX"
                            ZoomMode="X"
                            AnimationsSpeed="0:0:0"
                            LegendPosition="Hidden"
                            Background="#FFFFFF"/>
        <!-- Volume pane -->
        <lvc:CartesianChart Grid.Row="2"
                            Series="{Binding VolumeSeries}"
                            XAxes="{Binding VolumeXAxes}"
                            YAxes="{Binding VolumeYAxes}"
                            DrawMarginFrame="{Binding VolumeDrawMarginFrame}"
                            DrawMargin="{Binding VolumeDrawMargin}"
                            TooltipPosition="Top"
                            FindingStrategy="CompareOnlyX"
                            ZoomMode="X"
                            AnimationsSpeed="0:0:0"
                            LegendPosition="Hidden"
                            Background="#FFFFFF"
                            Margin="0,2,0,0"/>
      </Grid>
    </Border>

    <!-- Bottom controls (max height + scroll so chart stays visible) -->
    <Border Grid.Row="2" Classes="glass-bar" Padding="12" MaxHeight="300">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <Grid ColumnDefinitions="1.35*,1.25*,1*,1.05*" ColumnSpacing="12" MinHeight="200">

        <StackPanel Spacing="6">
          <TextBlock Classes="section" Text="전략 · 시간봉"/>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="10">
            <TextBlock Classes="sub" Text="시간봉" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding TimeframeOptions}"
                      SelectedItem="{Binding SelectedTimeframe}" MinWidth="150"/>
            <TextBlock Grid.Row="1" Classes="sub" Text="전략" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding StrategyOptions}"
                      SelectedItem="{Binding SelectedStrategy}" MinWidth="150"/>
            <TextBlock Grid.Row="2" Classes="sub" Text="종목" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WatchSymbolsText}" FontWeight="SemiBold" Foreground="#0F172A"/>
          </Grid>
          <TextBlock Classes="sub" Text="{Binding StrategyDescription}" TextWrapping="Wrap" Foreground="#1D4ED8"/>
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
            <CheckBox IsChecked="{Binding NewsDay}" Content="뉴스데이 (사이즈 50%)"/>
          </StackPanel>
          <TextBlock Classes="sub" Text="{Binding ContingencyLabel}" TextWrapping="Wrap" Foreground="#B45309"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button Classes="glass-btn" Content="자동매매 시작"
                    Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
            <Button Classes="glass-btn-stop" Content="종료"
                    Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"/>
            <Button Classes="glass-btn" Content="새로고침"
                    Command="{Binding RefreshCommand}" IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>
          <TextBlock Classes="sub" Text="{Binding ConnectionLabel}" TextWrapping="Wrap"/>
          <TextBlock Classes="sub" Text="{Binding StatusLine}"/>
        </StackPanel>

        <Border Classes="glass-card" Grid.Column="1" Padding="12" Background="#F8FAFC">
          <StackPanel Spacing="4">
            <TextBlock Classes="section" Text="지정가 · 익절 · 손절"/>
            <TextBlock Classes="sub" Text="{Binding OrderTypeLabel}" Foreground="#2563EB"/>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="10">
              <TextBlock Classes="sub" Text="ENTRY"/>
              <TextBlock Grid.Column="1" Classes="metric" Foreground="#2563EB" Text="{Binding EntryLimitLabel}"/>
              <TextBlock Grid.Row="1" Classes="sub" Text="SL"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Classes="metric" Foreground="#F23645" Text="{Binding StopLossLabel}"/>
              <TextBlock Grid.Row="2" Classes="sub" Text="TP"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Classes="metric" Foreground="#089981" Text="{Binding TakeProfitLabel}"/>
              <TextBlock Grid.Row="3" Classes="sub" Text="수량"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding QuantityPlanLabel}"/>
              <TextBlock Grid.Row="4" Classes="sub" Text="리스크"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RiskAmountLabel}"/>
              <TextBlock Grid.Row="5" Classes="sub" Text="R:R"/>
              <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RewardRiskLabel}"/>
              <TextBlock Grid.Row="6" Classes="sub" Text="수수료"/>
              <TextBlock Grid.Row="6" Grid.Column="1" Foreground="#B45309" Text="{Binding CommissionLabel}"/>
              <TextBlock Grid.Row="7" Classes="sub" Text="R:R 순"/>
              <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding NetRrLabel}"/>
              <TextBlock Grid.Row="8" Classes="sub" Text="ATR"/>
              <TextBlock Grid.Row="8" Grid.Column="1" FontSize="11" Text="{Binding AtrLabel}"/>
            </Grid>
            <TextBlock Classes="sub" Text="{Binding RecommendedStrategyNote}" TextWrapping="Wrap" Foreground="#334155"/>
            <TextBlock Classes="sub" Text="{Binding BracketSummary}" TextWrapping="Wrap" FontSize="10" Opacity="0.85"/>
          </StackPanel>
        </Border>

        <Border Classes="glass-card" Grid.Column="2" Padding="12">
          <StackPanel Spacing="8" VerticalAlignment="Center">
            <TextBlock Classes="section" Text="잔액"/>
            <TextBlock Classes="metric" FontSize="18" Text="{Binding BalanceLabel}" TextWrapping="Wrap"/>
            <TextBlock Classes="sub" Text="{Binding SessionStatusLabel, StringFormat=상태 · {0}}"/>
            <TextBlock Classes="section" Margin="0,6,0,0" Text="수익률"/>
            <TextBlock FontSize="26" FontWeight="Bold" Foreground="#089981" Text="{Binding ReturnRateLabel}"/>
            <TextBlock Classes="sub" Text="세션 · 투자 조언 아님"/>
          </StackPanel>
        </Border>

        <!-- Right column: legend on top + SPCX news card below -->
        <Grid Grid.Column="3" RowDefinitions="Auto,*" MinWidth="200">
          <Border Classes="glass-card" Padding="10" Margin="0,0,0,8">
            <StackPanel Spacing="5">
              <TextBlock Classes="section" Text="차트 범례"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Rectangle Width="18" Height="2" Fill="#2563EB"/>
                <TextBlock Classes="sub" Text="ENTRY" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Rectangle Width="18" Height="2" Fill="#F23645"/>
                <TextBlock Classes="sub" Text="SL" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Rectangle Width="18" Height="2" Fill="#089981"/>
                <TextBlock Classes="sub" Text="TP" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="12" Height="12" Fill="#66089981"/>
                <TextBlock Classes="sub" Text="버블=대금" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Classes="sub" TextWrapping="Wrap" Text="KST · Crosshair · 실주문 잠금"/>
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Classes="glass-card" Padding="10">
            <DockPanel LastChildFill="True">
              <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="section" Text="SPCX 뉴스" VerticalAlignment="Center"/>
                  <Button Grid.Column="1" Classes="glass-btn" Content="갱신"
                          Padding="8,4" FontSize="11"
                          Command="{Binding RefreshNewsOnlyCommand}"/>
                </Grid>
                <TextBlock Classes="sub" Text="{Binding NewsStatus}" TextWrapping="Wrap" FontSize="10"/>
                <TextBlock Classes="sub" TextWrapping="Wrap" FontSize="10"
                           Text="실헤드라인(RSS) · 감성 자동매매 금지"/>
              </StackPanel>
              <ListBox ItemsSource="{Binding NewsItems}"
                       Background="Transparent"
                       BorderThickness="0"
                       MinHeight="120"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:NewsItemRow">
                    <Border Background="#F8FAFC" CornerRadius="8" Padding="8" Margin="0,0,0,6"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Title}" TextWrapping="Wrap" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#0F172A"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding Badge}" FontSize="10" Foreground="#B91C1C"
                                     FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding Meta}" FontSize="10" Foreground="#64748B"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>
        </Grid>
      </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
